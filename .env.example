# Core app settings
SECRET_KEY=change-me-to-a-long-random-value
PORT=5000

# PostgreSQL connection (preferred)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional fallback PostgreSQL fields if DATABASE_URL is not set
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=sara_wms
PGUSER=postgres
PGPASSWORD=
PGSSLMODE=prefer

# Security and CORS
SESSION_COOKIE_SECURE=true
CORS_ORIGINS=https://your-render-service.onrender.com
